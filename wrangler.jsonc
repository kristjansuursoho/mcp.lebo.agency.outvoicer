{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mcp-lebo-agency-outvoicer",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-22",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    { "pattern": "mcp.lebo.agency/outvoicer/*", "zone_name": "lebo.agency" },
    {
      "pattern": "mcp.lebo.agency/.well-known/oauth-protected-resource/outvoicer/*",
      "zone_name": "lebo.agency",
    },
  ],
  "vars": {
    "NODE_ENV": "production",
    "MCP_ALLOWED_HOSTS": "mcp.lebo.agency",
    "MCP_ALLOWED_ORIGINS": "chatgpt.com",
    "MCP_PUBLIC_ORIGIN": "https://mcp.lebo.agency",
    "OAUTH_ISSUER": "https://oauth.lebo.agency",
    "OAUTH_JWKS_URL": "https://oauth.lebo.agency/.well-known/jwks.json",
    "OAUTH_CREDENTIAL_URL": "https://oauth.lebo.agency/api/outvoicer/credential",
  },
}
