{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["oxc", "typescript", "unicorn", "react", "import"],
  "categories": {
    "correctness": "warn"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "**/.nx/**",
    "**/.svelte-kit/**",
    "**/build/**",
    "**/public/**",
    "**/.ignore/**",
    "**/coverage/**",
    "node_modules/**",
    "**/dist/**",
    "**/snap/**",
    "**/vite.config.*.timestamp-*.*",
    "eslint.config.js",
    ".prettierrc"
  ]
}
